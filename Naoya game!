-- Money remote logic
local remote = game:GetService("ReplicatedStorage"):WaitForChild("AddDieMoney", 10)

local running = false

infButton.MouseButton1Click:Connect(function()
    if not remote then
        infButton.Text = "Remote missing"
        infButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        task.wait(1.8)
        infButton.Text = "Infinite Money"
        infButton.BackgroundColor3 = Color3.fromRGB(0, 170, 100)
        return
    end
    
    running = not running
    
    if running then
        infButton.Text = "Running... (click to stop)"
        infButton.BackgroundColor3 = Color3.fromRGB(220, 140, 0)
        
        spawn(function()
            while running and remote.Parent do
                task.spawn(function()
                    pcall(function()
                        remote:FireServer(4999)
                    end)
                end)
                task.wait()   -- ≈60/sec — change to task.wait(0.06) if too aggressive
            end
            if infButton.Parent then
                infButton.Text = "Infinite Money"
                infButton.BackgroundColor3 = Color3.fromRGB(0, 170, 100)
            end
        end)
    else
        infButton.Text = "Infinite Money"
        infButton.BackgroundColor3 = Color3.fromRGB(0, 170, 100)
    end
end)
